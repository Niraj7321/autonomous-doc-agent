# Copy to `.env` and fill in whichever provider you have.
# The agent works with ZERO keys (deterministic offline engine), but a real
# LLM produces richer, more tailored documents.

# --- Groq (recommended free tier: https://console.groq.com) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (free tier: https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Ollama (local, https://ollama.com) ---
# Set USE_OLLAMA=1 only if `ollama serve` is running.
USE_OLLAMA=0
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Runtime tuning ---
OUTPUT_DIR=generated
LLM_TIMEOUT=45
LLM_MAX_RETRIES=2
